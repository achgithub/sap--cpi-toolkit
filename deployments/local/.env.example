# Local development environment
# Copy to .env — it is gitignored

# Auth bypass — only works when DEPLOYMENT_ENV=local
DEPLOYMENT_ENV=local
AUTH_BYPASS_ENABLED=true

# Portal
PORTAL_PORT=3000
BASE_URL=http://localhost:3000
WORKER_INTERNAL_URL=http://worker:8081
GROOVY_INTERNAL_URL=http://groovy-runner:8082

# Worker
WORKER_PORT=8081

# Groovy runner
GROOVY_PORT=8082

# PostgreSQL
POSTGRES_USER=toolkit
POSTGRES_PASSWORD=toolkit
POSTGRES_DB=toolkit
DB_URL=postgres://toolkit:toolkit@postgres:5432/toolkit?sslmode=disable

# Key/cert validity caps
KEY_VALIDITY_MAX_DAYS=365
CERT_VALIDITY_MAX_DAYS=90

# IAS — leave empty for local bypass; fill in to test real IAS locally
IAS_CLIENT_ID=
IAS_CLIENT_SECRET=
IAS_TENANT_URL=
