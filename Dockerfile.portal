# Stage 1: Build React UI
FROM node:20-alpine AS web-builder
WORKDIR /app/web
COPY web/package*.json ./
RUN npm install
COPY web/ ./
RUN npm run build
# Output: /app/web/dist/

# Stage 2: Build Go binary (with embedded React)
FROM golang:1.25-alpine AS go-builder
WORKDIR /app
COPY go.mod ./
RUN go mod download
COPY . .
# Copy React build into the location the portal embeds from
COPY --from=web-builder /app/web/dist ./cmd/portal/static
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /portal ./cmd/portal

# Stage 3: Minimal runtime image
FROM gcr.io/distroless/static-debian12
COPY --from=go-builder /portal /portal
EXPOSE 3000
ENTRYPOINT ["/portal"]
